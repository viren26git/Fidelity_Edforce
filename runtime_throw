package fidelity.programs;

import java.util.Scanner;

class Student{
	
	static void checkMarks(int marks)
	{
		if(marks < 0 || marks >100)
		{
			throw new ArithmeticException("Marks cannot be either negative or more than 100");
		}
		System.out.println("marks are " + marks); 
	}
}

public class CTEDemo2 {
	public static void main(String[] args) {
		
		System.out.println("Enter the marks...");
		Scanner s = new Scanner(System.in);
		int a = s.nextInt();
	
		try
		{
			Student.checkMarks(a);  // calling my static method inside the other class
		}
		catch(Exception e)
		{
			System.out.println(e.getMessage()); 
		}
	}
}
