package fidelity.programs;

public class ExceptionDemo1 {
	public static void main(String[] args) {
		
     int a= 10;
     int b=0;
     
     int arr[] = new int[5];  
     
     try{
    	 try{
    		 System.out.println("inside the first try");
    		 System.out.println(arr[6]);   // ---> arrayIndexOutOfBound
    	 }
    	 catch(ArrayIndexOutOfBoundsException ae)
         {
        	 System.out.println(ae.getMessage());
         }
    	 finally{
    		 System.out.println("Inside the fianlly of inner try -1");
    	 }
    	 
    	 try{
    		 System.out.println("inside the second try");
    		 int c = a/b;                          // ---> Arithmetic Exception 
    	     System.out.println("The result of division is :" + c);
    	 }
    	 catch(NullPointerException e)
         {
        	 System.out.println(e.getMessage());
         }   
     }
     catch(Exception e)
     {
    	 System.out.println("inside the outer catch block");
    	 System.out.println(e.getMessage());
     }
     finally{
    	 System.out.println("We are calling the finally code");
     }
	}
}
