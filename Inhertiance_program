package fidelity.programs;

class EmployeParent
{
	int age;
	String name;
	String dept;
	
	public EmployeParent(int age, String name, String dept)
	{
		this.age= age;
		this.name=name;
		this.dept=dept;
	}
	
	void disp(){
		System.out.println("The employee name is :" + name + " and age is : " + age + "and working in dept :" +dept); 
	}
}

class Person extends EmployeParent
{
	float salary;
	String city;
	
	public Person(int age, String name, String dept,float salary, String city)
	{
		super(age,name,dept);
		this.salary=salary;
		this.city=city;
	}
	
	void display()
	{
		System.out.println("======= In child class method=====");
		System.out.println("The employee name is :" + name + " residing in city:" + city +" with salary as" + salary +" and age is : " + age + "and working in dept :" +dept); 
	}
}

public class InheritanceDemo {

	public static void main(String[] args) {
		
		Person p = new Person(34,"Ravi","IT",45000.00f,"Delhi");
		
		System.out.println("The name of the employee is "+ p.name); 
		p.disp();
		p.display();

	}
}
